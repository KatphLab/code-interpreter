# MCP Code Interpreter - Environment Configuration Example
# Copy this file to .env and customize the values as needed

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================

# API key for authenticating REST/MCP requests
# If set, all endpoints require the X-API-Key header with this value
# Leave empty for open access (not recommended for production)
CODE_INTERPRETER_API_KEY=dev-demo-key

# Maximum number of concurrent kernel sessions (default: 50)
MAX_SESSIONS=50

# Execution timeout in seconds for code runs (default: 300)
EXECUTION_TIMEOUT=300

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Enable HTTP request/response logging for debugging (default: false)
# Set to true to log all incoming requests and responses
LOG_REQUESTS=false

# =============================================================================
# SUBPROCESS RESOURCE LIMITS
# =============================================================================

# Maximum memory per subprocess in MB (0 = unlimited, default: 0)
# Applies to bash, node, typescript, go, and C++ executions
SUBPROCESS_MAX_MEMORY_MB=512

# Maximum CPU time per subprocess in seconds (0 = unlimited, default: 0)
SUBPROCESS_MAX_CPU_SECONDS=60

# Enable bash strict mode: set -euo pipefail (default: true)
# When enabled, bash scripts exit on errors and unset variables
BASH_STRICT_MODE=true

# =============================================================================
# DIRECTORY PATHS
# =============================================================================

# Base directory for the application (default: current working directory)
# APP_BASE_DIR=/app

# Directory for storing notebooks (default: {APP_BASE_DIR}/notebooks)
# NOTEBOOKS_DIR=/app/notebooks

# Directory for file uploads (default: {APP_BASE_DIR}/uploads)
# UPLOADS_DIR=/app/uploads

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed CORS origins (default: * = all origins)
# For production, set to specific origins:
# CORS_ALLOW_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ALLOW_ORIGINS=*

# =============================================================================
# DOCKER/DEPLOYMENT SETTINGS
# =============================================================================

# User and Group IDs for the app user inside the container (default: 1000)
# Change these to match your host user's IDs to avoid permission issues
APP_UID=1000
APP_GID=1000

# Port the server listens on (default: 8000)
PORT=8000

# Join an existing external Docker network (default: false)
# Set to true when the interpreter needs to communicate with other containers
MCP_NETWORK_EXTERNAL=false

# Name of the external Docker network to join (default: mcp-network)
MCP_NETWORK_NAME=mcp-network

# =============================================================================
# E2E TESTING (used by Makefile and test scripts)
# =============================================================================

# Base URL for end-to-end tests (default: http://localhost:8000)
# BASE_URL=http://localhost:8000

# Directory for e2e test artifacts (default: e2e/runs)
# RUNS_DIR=e2e/runs

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. For Docker deployments, create this file as .env in the project root
#    and run: docker compose up -d
#
# 2. For local development with UV, you can export variables:
#    export CODE_INTERPRETER_API_KEY=secret-key
#    make dev
#
# 3. Boolean values should be set as: true/false, 1/0, or yes/no
#
# 4. Resource limits (SUBPROCESS_MAX_*) only apply to non-Python languages
#    (bash, node, typescript, go, C++). Python execution uses Jupyter
#    kernels which have their own resource management.
#
# 5. Setting MCP_NETWORK_EXTERNAL=true requires the network to already exist
#    or the quickstart.sh script will create it for you.
#
# 6. Never commit your actual .env file with real secrets to version control!
#    This .env.example file is safe to commit as a template.
